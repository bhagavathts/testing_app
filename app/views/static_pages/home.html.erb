<%provide(:title,"Home") %>
<%if logged_in? %>
  <div class="row">
    <aside class="col-md-4">
      <section class="user_info">
        <%=render 'shared/user_info' %>
      </section>
      <section class="micropost_form">
        <%=render 'shared/micropost_form' %>
      </section>
    </aside>
  </div>
<%else %>
  <div class="center jumbotron">
    <h1>Welcome to Sample App</h1>
    <h2>
      This is the home page for the Ruby on rails tutorial app.
    </h2>


    <%= link_to "Sign Up now!",signup_path,class:"btn btn-primary btn-lg" %>
  </div>
  <%=link_to image_tag("rails.svg",alt:"Rails logo"),'http://rubyonrails.org' %>
<% end %>
