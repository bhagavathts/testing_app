<% provide(:title, 'Login') %>
<h1>LOGIN</h1>
<div class="row">
  <div class="col-md-6 offset-md-3" >

    <%= form_for(:session,url:login_path) do |f| %>
      <div style="display: flex;flex-direction: column;gap: 15px;">

        <%= f.label :email %>
        <%= f.email_field :email ,class:"form-control"%>
        <%= f.label :password,class:"d-inline"%>
        <%= link_to "(forgot password)", new_password_reset_path, class: "ms-2 small" %>
        <%= f.password_field :password ,class:"form-control"%>

        <div style="text-align:left;">
          <%= f.label :remember_me, style: "display:inline-flex; align-items:center; gap:6px; white-space:nowrap;" do %>
            <%= f.check_box :remember_me %>
            <span>Remember me on this computer</span>
          <% end %>
        </div>
        <%= f.submit "Log in", class: "btn btn-primary" %>
      </div>

    <% end %>
    <p>New user?  <%=link_to "sign up",signup_path %> </p>
  </div>
</div>